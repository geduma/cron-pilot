{
  "name": "cron-pilot",
  "version": "1.0.0",
  "description": "Schedule and monitor HTTP jobs",
  "type": "module",
  "scripts": {
    "dev": "npm run build:frontend && tsx watch src/index.ts",
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/utils/migrate.ts",
    "setup": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.10.5",
    "@types/better-sqlite3": "^7.6.12"
  }
}
